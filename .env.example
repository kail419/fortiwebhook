# ============================================================================
#  IPsecAlert configuration — copy to `.env` and fill in.  Never commit `.env`.
# ============================================================================

# ---- Webhook authentication -------------------------------------------------
# Shared secret FortiGate must send. Generate e.g.: openssl rand -hex 32
WEBHOOK_TOKEN=change-me-to-a-long-random-secret
# HTTP header FortiGate sends the token in (recommended over query string).
WEBHOOK_TOKEN_HEADER=X-Webhook-Token

# ---- HTTP server ------------------------------------------------------------
# Port INSIDE the container. The Caddy proxy reaches it over the compose network.
LISTEN_PORT=8080
LOG_LEVEL=INFO

# ---- Reverse proxy / HTTPS (Caddy) ------------------------------------------
# What the Caddy proxy serves on. See Caddyfile for the TLS options.
#   :443                        -> HTTPS with a self-signed internal cert (default)
#   ipsecalert.corp.example.com -> automatic public HTTPS (Let's Encrypt)
SITE_ADDRESS=:443

# ---- LDAP / Active Directory ------------------------------------------------
# Domain controller host (or ldaps://host). LDAPS is strongly recommended.
LDAP_SERVER=dc01.corp.example.com
LDAP_USE_SSL=true
LDAP_PORT=636
# Read-only service account used to bind. UPN or full DN both work.
LDAP_BIND_DN=svc-ipsecalert@corp.example.com
LDAP_BIND_PASSWORD=service-account-password
# Search base for user lookups.
LDAP_BASE_DN=DC=corp,DC=example,DC=com
# Filter template. {user} is replaced with the (escaped) account name.
# For UPN logins you could use: (userPrincipalName={user}@corp.example.com)
LDAP_USER_FILTER=(sAMAccountName={user})
# AD attribute holding the e-mail address.
LDAP_EMAIL_ATTR=mail
# Strip a UPN suffix (user@domain -> user) before matching sAMAccountName.
LDAP_STRIP_UPN_SUFFIX=true
LDAP_TIMEOUT=10

# ---- SMTP -------------------------------------------------------------------
SMTP_HOST=smtp.corp.example.com
SMTP_PORT=587
# Use exactly one of the two below. STARTTLS (587) is the common default.
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
# Leave blank for an internal relay that allows unauthenticated submission.
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TIMEOUT=15
MAIL_FROM=security-alert@corp.example.com
MAIL_FROM_NAME=IT Security Alert
# Optional extra recipients (comma-separated).
MAIL_CC=
MAIL_BCC=
MAIL_REPLY_TO=itsec@corp.example.com
MAIL_SUBJECT=[資安通知] 偵測到您的帳號自海外連線 VPN / Security Alert
# Shown in the e-mail body/footer. Leave blank to omit.
ORG_NAME=
# Who the user should contact if the login wasn't them (phone/ext/e-mail).
SECURITY_CONTACT=資安專線 #1234 / itsec@corp.example.com

# ---- Behaviour --------------------------------------------------------------
# Comma-separated country names to NOT alert on (matched case-insensitively
# against %%srccountry%%). Defence-in-depth on top of the FortiGate filter.
IGNORE_COUNTRIES=Taiwan,Reserved
# Suppress duplicate alerts for the same user+IP within this many seconds.
DEDUP_WINDOW_SECONDS=300
# Where to send a notice when the user's mailbox can't be resolved.
FALLBACK_EMAIL=itsec@corp.example.com
NOTIFY_FALLBACK_ON_MISSING=true

# ---- Concurrency (see gunicorn.conf.py) -------------------------------------
# Keep at 1 so the in-memory dedup cache stays correct.
WEB_CONCURRENCY=1
WEB_THREADS=4
