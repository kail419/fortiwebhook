# ============================================================================
#  IPsecAlert configuration — copy to `.env` and fill in.  Never commit `.env`.
# ============================================================================

# ---- Webhook authentication -------------------------------------------------
# Shared secret FortiGate must send. Generate e.g.: openssl rand -hex 32
WEBHOOK_TOKEN=change-me-to-a-long-random-secret
# HTTP header FortiGate sends the token in (recommended over query string).
WEBHOOK_TOKEN_HEADER=X-Webhook-Token
# More secure: keep secrets out of the environment by pointing *_FILE at a
# mounted file (Docker secret) instead of the inline value. Supported for
# WEBHOOK_TOKEN_FILE, LDAP_BIND_PASSWORD_FILE, SMTP_PASSWORD_FILE.
# WEBHOOK_TOKEN_FILE=/run/secrets/webhook_token

# ---- HTTP server ------------------------------------------------------------
# Port INSIDE the container. The Caddy proxy reaches it over the compose network.
LISTEN_PORT=8080
LOG_LEVEL=INFO

# ---- Reverse proxy / HTTPS (Caddy) ------------------------------------------
# Caddy listens on :443 inside the container and presents the company GoDaddy
# wildcard cert mounted at certs/ (see certs/README.md and the Caddyfile).
# Keep :443 here; FortiGate reaches it via HOST_HTTPS_PORT below, using an FQDN
# the wildcard covers (e.g. fortiwebhook.gss.com.tw) so the cert verifies.
SITE_ADDRESS=:443
# Hostname Caddy assumes when a client sends no SNI (health checks / curl to the
# IP). Must be a name your wildcard cert covers. FortiGate sends its own SNI.
TLS_DEFAULT_SNI=fortiwebhook.gss.com.tw
# Source IPs allowed to reach the service. "private_ranges" = internal networks
# only; tighten to the FortiGate's exact IP for best security, e.g. 10.10.1.1
FORTIGATE_IPS=private_ranges
# Bind the published HTTPS port to ONE internal interface (recommended), e.g.
# BIND_ADDR=10.10.1.5. Leave 0.0.0.0 to listen on all interfaces.
BIND_ADDR=0.0.0.0
# Host port to publish HTTPS on. Default 18443 avoids clashing with other
# services on the same host (e.g. avss on 443). Container serves 443 internally.
HOST_HTTPS_PORT=18443

# ---- LDAP / Active Directory ------------------------------------------------
# Domain controller host (or ldaps://host). LDAPS is strongly recommended.
LDAP_SERVER=dc01.corp.example.com
LDAP_USE_SSL=true
LDAP_PORT=636
# Verify the DC's TLS certificate (keep true). For an internal CA, point
# LDAP_CA_CERT at the root/chain PEM and mount it into the container.
LDAP_TLS_VALIDATE=true
LDAP_CA_CERT=
# Read-only service account used to bind. UPN or full DN both work.
LDAP_BIND_DN=svc-ipsecalert@corp.example.com
LDAP_BIND_PASSWORD=service-account-password
# Search base for user lookups.
LDAP_BASE_DN=DC=corp,DC=example,DC=com
# Filter template. {user} is replaced with the (escaped) account name.
# For UPN logins you could use: (userPrincipalName={user}@corp.example.com)
LDAP_USER_FILTER=(sAMAccountName={user})
# AD attribute holding the e-mail address.
LDAP_EMAIL_ATTR=mail
# Strip a UPN suffix (user@domain -> user) before matching sAMAccountName.
LDAP_STRIP_UPN_SUFFIX=true
LDAP_TIMEOUT=10

# ---- SMTP -------------------------------------------------------------------
SMTP_HOST=smtp.corp.example.com
SMTP_PORT=587
# Use exactly one of the two below. STARTTLS (587) is the common default.
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
# SMTP AUTH login. Set BOTH only if the relay requires it; leave BOTH blank for
# an unauthenticated internal relay (e.g. port 25). This is the login account,
# NOT the sender — the sender is MAIL_FROM below.
SMTP_USERNAME=
SMTP_PASSWORD=
# Optional CA bundle to trust for the relay's TLS cert (internal CA).
SMTP_CA_CERT=
SMTP_TIMEOUT=15
MAIL_FROM=security-alert@corp.example.com
MAIL_FROM_NAME=IT Security Alert
# Optional extra recipients (comma-separated).
MAIL_CC=
MAIL_BCC=
MAIL_REPLY_TO=itsec@corp.example.com
MAIL_SUBJECT=[資安通知] 偵測到您的帳號自 {{ country }} 連線 VPN / Security Alert
# Shown in the e-mail body/footer. Leave blank to omit.
ORG_NAME=
# Kept for compatibility with existing deployments; no longer shown in e-mail.
SECURITY_CONTACT=資安專線 #1234 / itsec@corp.example.com

# ---- Behaviour --------------------------------------------------------------
# Comma-separated country names to NOT alert on (matched case-insensitively
# against %%srccountry%%). Defence-in-depth on top of the FortiGate filter.
IGNORE_COUNTRIES=Taiwan,Reserved
# Suppress duplicate alerts for the same user+IP within this many seconds.
DEDUP_WINDOW_SECONDS=300
# Where to send a notice when the user's mailbox can't be resolved.
FALLBACK_EMAIL=itsec@corp.example.com
NOTIFY_FALLBACK_ON_MISSING=true

# ---- Optional FortiClient EMS overseas-connection monitor ------------------
# Enable with: docker compose --profile ems up -d --build
EMS_API_URL=https://ems.example.com
# Observed from the EMS 7.4.7 web console; override if a later patch changes it.
EMS_ENDPOINTS_PATH=/api/v1/endpoints/index?offset=0
# API token. Use EMS_API_TOKEN_FILE where possible.
EMS_API_TOKEN=
# EMS_API_TOKEN_FILE=/run/secrets/ems_api_token
# Adapt these if the FortiAPI page specifies a different authentication header.
EMS_API_TOKEN_HEADER=Authorization
EMS_API_TOKEN_PREFIX=Bearer
# Dotted path to the endpoint array and optional pagination link in the JSON.
EMS_ENDPOINTS_KEY=data.endpoints
EMS_NEXT_KEY=
EMS_TOTAL_KEY=data.total
EMS_OFFSET_PARAM=offset
EMS_API_TIMEOUT=20
EMS_POLL_SECONDS=60
EMS_MAX_PAGES=100
EMS_TLS_VALIDATE=true
# Internal CA bundle for EMS HTTPS, e.g. /certs/ems-internal-ca.pem.
EMS_CA_CERT=
# Keep false. Only for an isolated lab where EMS has no HTTPS listener.
EMS_ALLOW_HTTP=false

# Used only when the endpoint user's mailbox cannot be resolved.
EMS_ALERT_TO=security-alert@corp.example.com
# First run normally creates a baseline without alerting all existing devices.
EMS_ALERT_ON_INITIAL_SYNC=false
EMS_HOME_COUNTRIES=TW,Taiwan
EMS_STATE_FILE=/data/ems-state.db
EMS_GEOIP_DB=/geoip/GeoLite2-Country.mmdb

# API response field mappings. Values are comma-separated dotted JSON paths.
# Run `python -m app.ems_monitor --validate-api` to print available field names.
EMS_ID_FIELDS=uid,device_id,forticlient_id,uuid,endpoint_id,id
EMS_HOSTNAME_FIELDS=host,name,hostname,device_name
EMS_USER_FIELDS=fct_users.0.user_email,fct_users.0.auth_user_name,fct_users.0.machine_user_name,username
EMS_IP_FIELDS=public_ip_addr,ip_addr,public_ip,ip
EMS_COUNTRY_FIELDS=country_code,country,geo.country_code
EMS_STATUS_FIELDS=is_ems_online,connection_status,status,online
EMS_REGISTRATION_STATUS_FIELDS=is_ems_registered,registration_status
EMS_REGISTERED_FIELDS=registered_at,registration_time,created_at
EMS_LAST_SEEN_FIELDS=last_seen,fct_users.0.last_seen,last_seen_at
EMS_ONLINE_VALUES=online,connected,true,1
EMS_REGISTERED_VALUES=registered,true,1

# ---- Concurrency (see gunicorn.conf.py) -------------------------------------
# Keep at 1 so the in-memory dedup cache stays correct.
WEB_CONCURRENCY=1
WEB_THREADS=4
