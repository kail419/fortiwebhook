# IPsecAlert — internal TLS reverse proxy in front of the app.
#
# SITE_ADDRESS: what Caddy serves on. Default ":443" => HTTPS with a cert from
# Caddy's built-in local CA (import its root into FortiGate — see README §7).
# For a corporate-CA cert, use option C below.
#
# FORTIGATE_IPS: source addresses allowed to connect. Default "private_ranges"
# permits only RFC1918 internal networks; tighten to the FortiGate's exact IP:
#   FORTIGATE_IPS=10.10.1.1
{$SITE_ADDRESS::443} {

	# ---- TLS: company GoDaddy wildcard cert (mounted at /certs) ----------
	# fullchain.pem = your leaf cert + GoDaddy intermediate bundle (leaf first);
	# privkey.pem  = the matching private key. See certs/README.md.
	# FortiGate connects by an FQDN the wildcard covers (e.g.
	# fortiwebhook.gss.com.tw) and verifies against GoDaddy's trusted root.
	tls /certs/fullchain.pem /certs/privkey.pem
	# Alternatives: `tls internal` (self-signed local CA), or set SITE_ADDRESS to a
	# public domain and remove the line above for automatic Let's Encrypt.

	# 1) Reject any source that is not an allowed internal address.
	@untrusted not remote_ip {$FORTIGATE_IPS:private_ranges}
	handle @untrusted {
		respond "Forbidden" 403
	}

	# 2) Serve ONLY the webhook and health endpoints.
	@allowed path /webhook/* /health
	handle @allowed {
		reverse_proxy ipsecalert:8080 {
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# 3) Everything else is refused.
	handle {
		respond 404
	}

	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		-Server
	}

	log {
		output stdout
		format console
	}
}
